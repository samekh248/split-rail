{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=split-rail-db;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Jwt": {
    "Secret": "dev-secret-key-at-least-32-characters-long",
    "Issuer": "split-rail",
    "Audience": "split-rail-api",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "SettlementArchive": {
    "BucketName": "split-rail-settlements-dev",
    "StagingBucketName": "split-rail-settlements-staging-dev",
    "SignedUrlTtlMinutes": 15,
    "RetentionYears": 7,
    "UseInMemoryStore": false,
    "EnforceRetentionValidation": true
  }
}
